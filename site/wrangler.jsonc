{
  // Static-assets Worker: serve the pre-built Astro output in ./dist.
  // No "main" = no SSR worker; Wrangler deploys the static files directly.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "workhouse-website",
  "compatibility_date": "2026-07-07",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
