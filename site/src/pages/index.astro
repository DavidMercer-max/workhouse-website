---
import Base from '../layouts/Base.astro';
import Placeholder from '../components/Placeholder.astro';
import { getCollection } from 'astro:content';
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const posts = (await getCollection('blog')).sort((a, b) => b.data.order - a.data.order);

const clients = ['Mix Interiors', 'Stax', 'Sanipex Group', 'anywhere', 'Maldon', 'Peldon Rose', 'Yeo Valley', 'Crown Professional', 'Ian Mankin', 'Perx', 'Hempel', 'Singletons'];
const wins = ['Killer strategies that cut through', 'Ideas that ignite', 'Brands that stick', 'Creative assets impossible to ignore', 'Digital that delivers'];
const featured = [
  { cat: 'Branding', title: '[ Project title ]', catch: 'Case study / shot catch-line', client: 'Client' },
  { cat: 'Digital', title: '[ Project title ]', catch: 'Case study / shot catch-line', client: 'Client' },
  { cat: 'Branding', title: 'Making a new digital home for Mix.', catch: 'Case study catch-line', client: 'Mix Interiors' },
  { cat: 'Creative', title: 'A trade undercoat gets a makeover', catch: 'Case study catch-line', client: 'Crown Trade' },
  { cat: 'Strategy', title: '[ Project title ]', catch: 'Case study / shot catch-line', client: 'Client' },
];
---
<Base>
  <div class="note">SCREEN · Homepage reworked to the live layout — full-bleed hero → positioning + client logos → capability band → featured work → services → latest → newsletter footer. Lo-fi: all imagery is placeholder.</div>

  <!-- Full-bleed hero -->
  <div class="fullbleed"><Placeholder label="Hero image — full-bleed campaign visual" minHeight="clamp(300px,42vw,520px)" flush={true} /></div>

  <!-- Positioning + client logos -->
  <section style="margin-top:56px">
    <h1 style="max-width:780px">We work with <em>marketing leaders</em> who don't want to blend in.</h1>
    <p class="lead" style="margin-top:16px">They want to rise above the sea of sameness in their sector. They believe bold creative makes a difference. They're right. We're for the challengers with something to prove. The provocateurs pressured for proof. The ones who want their brand to mean something.</p>

    <div class="logo-grid" style="margin-top:44px">
      {clients.map((c) => <div class="logo-box">{c}</div>)}
    </div>
  </section>

  <!-- Capability band -->
  <section class="fullbleed" style="background:var(--soft-blue);margin-top:64px;padding:56px 0;">
    <div class="container">
      <div class="grid c2" style="align-items:start">
        <p class="lead" style="color:var(--primary)">We turn complex worlds into remarkable stories that clients can get behind. We help brands find their greatness through action-provoking creative that makes people think, feel and act differently.</p>
        <ul class="underline-list">{wins.map((w) => <li>{w}</li>)}</ul>
      </div>
      <div style="text-align:center;margin-top:36px"><a class="btn primary" href="/what-we-do">What we do ↗</a></div>
    </div>
  </section>

  <!-- Featured work -->
  <section style="margin-top:64px">
    <h2>Featured work</h2>
    <div class="hscroll" style="margin-top:18px">
      {featured.map((f) => (
        <a href="/work/case-study" class="card" style="padding:0;overflow:hidden">
          <Placeholder label={f.cat} minHeight="200px" flush={true} />
          <div style="padding:18px">
            <span class="tag">{f.cat}</span>
            <h3 style="margin-top:8px;font-size:18px">{f.title}</h3>
            <p class="muted" style="font-size:13px;margin:4px 0 2px">{f.catch}</p>
            <p class="muted" style="font-size:12px">{f.client}</p>
          </div>
        </a>
      ))}
    </div>
    <a class="btn" style="margin-top:16px" href="/work">See all work ↗</a>
  </section>

  <!-- Services -->
  <section style="margin-top:72px">
    <div class="grid c2" style="align-items:center">
      <div>
        <h2>Services</h2>
        <p class="muted" style="max-width:430px">Strategy, creative and digital — three disciplines, one obsession: work that provokes a response. We own our clients' challenges like they're ours.</p>
        <div style="margin-top:20px">
          {services.map((s) => (
            <a class="svc-row" href={`/what-we-do/${s.id}`}>
              <span class="name">{s.data.eyebrow}</span>
              <span class="arr">↗</span>
            </a>
          ))}
        </div>
      </div>
      <Placeholder label="Feature image" minHeight="360px" />
    </div>
  </section>

  <!-- Latest -->
  <section style="margin-top:72px">
    <span class="eyebrow">Latest</span>
    <h2>Fresh thinking</h2>
    <div class="hscroll" style="margin-top:18px">
      {posts.slice(0, 5).map((p) => (
        <a href={`/latest/${p.id}`} class="card" style="padding:0;overflow:hidden">
          <Placeholder minHeight="180px" flush={true} />
          <div style="padding:16px">
            <span class="tag">{p.data.pillar}</span>
            <h3 style="margin-top:8px;font-size:16px">{p.data.title}</h3>
          </div>
        </a>
      ))}
    </div>
    <a class="btn" style="margin-top:16px" href="/latest">All perspectives ↗</a>
  </section>
</Base>
