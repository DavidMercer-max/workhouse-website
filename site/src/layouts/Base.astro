---
import '../styles/global.css';
const { title = 'Workhouse — Creative agency for the Built Environment', description = 'Action-provoking creative for the built environment.' } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  { href: '/about', label: 'Approach' },
  { href: '/work', label: 'Work' },
  { href: '/latest', label: 'Perspectives' },
  { href: '/agency-life', label: 'Agency life' },
  { href: '/contact', label: 'Contact' },
];
const isActive = (href) => path === href || path.startsWith(href + '/');
---
<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
</head>
<body>
  <header class="site">
    <a class="logo" href="/">Workhouse</a>
    <nav class="site">
      {nav.map((n) => <a href={n.href} class={isActive(n.href) ? 'active' : ''}>{n.label}</a>)}
    </nav>
  </header>

  <main class="container screen">
    <slot />
  </main>

  <footer class="site">
    <div class="footer-inner">
      <h2>Bringing perspective to brand, design &amp; build</h2>
      <div class="footer-grid">
        <nav>
          <a href="/about">Approach</a>
          <a href="/work">Work</a>
          <a href="/latest">Perspectives</a>
          <a href="/agency-life">Agency life</a>
          <a href="/careers">Jobs</a>
          <a href="/contact">Contact</a>
        </nav>
        <div class="newsletter">
          <p class="muted" style="max-width:420px">Sign up to our E-news for our fresh thinking and unique perspectives.</p>
          <label class="eyebrow" style="color:#8a8069">Email</label>
          <input class="inp" type="email" placeholder="you@company.com" />
          <p class="muted" style="font-size:12px;margin-top:8px">By entering your email address you agree to the <a href="#" style="display:inline">T&amp;Cs</a>.</p>
          <span class="eyebrow" style="color:#8a8069;margin-top:14px">Social</span>
          <div class="social"><span>Fb</span><span>Ig</span><span>In</span></div>
        </div>
      </div>
    </div>
    <div class="footer-legal">
      <span>© 2026 Workhouse Marketing. All rights reserved.</span>
      <a href="#">Terms &amp; Conditions</a>
      <a href="#">Privacy Policy</a>
      <a href="#">Lobbying Policy</a>
      <span style="font-family:var(--font-mono)">· Lo-fi wireframe · placeholder imagery</span>
    </div>
  </footer>
</body>
</html>
