---
import '../styles/global.css';
const { title = 'Workhouse — Creative agency for the Built Environment', description = 'Action-provoking creative for the built environment.' } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  { href: '/what-we-do', label: 'What We Do' },
  { href: '/work', label: 'Work' },
  { href: '/sectors', label: 'Sectors' },
  { href: '/latest', label: 'Latest' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const isActive = (href) => path === href || path.startsWith(href + '/');
---
<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
</head>
<body>
  <header class="site">
    <a class="logo" href="/">Workhouse</a>
    <nav class="site">
      {nav.map((n) => <a href={n.href} class={isActive(n.href) ? 'active' : ''}>{n.label}</a>)}
    </nav>
  </header>

  <main class="container screen">
    <slot />
  </main>

  <footer class="site">
    <div class="fcols">
      <div>
        <div class="logo" style="color:var(--neutral)">Workhouse</div>
        <p class="muted" style="max-width:280px;margin-top:10px">Action-provoking creative for the built environment.</p>
      </div>
      <div><span class="eyebrow" style="color:var(--soft-yellow)">Explore</span><a href="/what-we-do">What We Do</a><a href="/work">Work</a><a href="/sectors">Sectors</a><a href="/latest">The Latest</a></div>
      <div><span class="eyebrow" style="color:var(--soft-yellow)">Agency</span><a href="/about">About</a><a href="/careers">Careers</a><a href="/b-corp">B Corp</a></div>
      <div><span class="eyebrow" style="color:var(--soft-yellow)">Talk to us</span><a href="/contact">Contact</a><span class="muted" style="font-size:13px">01254 878 956<br>hello@workhouse.agency</span></div>
    </div>
    <p class="muted" style="max-width:var(--wrap);margin:30px auto 0;font-size:12px;font-family:var(--font-mono)">Low-fidelity wireframe · placeholder imagery · fonts are stand-ins for Denton Bold &amp; Gotham Book</p>
  </footer>
</body>
</html>
